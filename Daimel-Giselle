<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Horario · Daimel & Giselle (A & B)</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,600;9..144,800&family=JetBrains+Mono:wght@400;600&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{--bg:#fafaf7;--bg-soft:#f3f2ed;--panel:#ffffff;--panel-2:#f7f6f1;--line:#e5e2d8;--line-strong:#cfcabd;--ink:#1a1d24;--ink-soft:#5a6275;--ink-dim:#8a93a6;--accent:#2d8c7a;--accent-2:#c47e1f;--staff-daimel:#3a6db8;--staff-giselle:#b8438a;--shadow:0 20px 50px -25px rgba(40,30,15,.18);--shadow-soft:0 4px 14px -6px rgba(40,30,15,.08)}
  *{box-sizing:border-box;margin:0;padding:0}
  html,body{background:var(--bg);color:var(--ink);font-family:'Outfit',sans-serif;line-height:1.5;-webkit-font-smoothing:antialiased}
  body{min-height:100vh;background:radial-gradient(circle at 15% 0%, rgba(45,140,122,.05), transparent 50%),radial-gradient(circle at 85% 100%, rgba(196,126,31,.04), transparent 50%),var(--bg);padding:32px 20px 80px}
  .wrap{max-width:1180px;margin:0 auto}
  header{display:flex;justify-content:space-between;align-items:flex-end;border-bottom:1px solid var(--line);padding-bottom:24px;margin-bottom:40px;flex-wrap:wrap;gap:20px}
  .brand{display:flex;flex-direction:column;gap:4px}
  .brand-tag{font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.18em;color:var(--accent);text-transform:uppercase}
  .brand h1{font-family:'Fraunces',serif;font-weight:300;font-size:clamp(28px,4vw,44px);letter-spacing:-.02em;line-height:1.05;color:var(--ink)}
  .brand h1 em{font-style:italic;font-weight:400;color:var(--accent)}
  .clock{text-align:right;font-family:'JetBrains Mono',monospace;color:var(--ink-soft);font-size:13px;line-height:1.7}
  .clock strong{color:var(--ink);display:block;font-size:15px;font-weight:600;text-transform:capitalize}
  .today{background:linear-gradient(135deg,var(--panel) 0%,var(--panel-2) 100%);border:1px solid var(--line);border-radius:24px;padding:36px 40px;box-shadow:var(--shadow);margin-bottom:48px;position:relative;overflow:hidden}
  .today::before{content:"";position:absolute;top:-50%;right:-10%;width:50%;height:200%;background:radial-gradient(circle,rgba(45,140,122,.06),transparent 60%);pointer-events:none}
  .today-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;flex-wrap:wrap;gap:12px}
  .today-label{font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);display:flex;align-items:center;gap:10px}
  .pulse{width:8px;height:8px;border-radius:50%;background:var(--accent);box-shadow:0 0 0 0 var(--accent);animation:pulse 2s infinite}
  @keyframes pulse{0%{box-shadow:0 0 0 0 rgba(45,140,122,.5)}70%{box-shadow:0 0 0 12px rgba(45,140,122,0)}100%{box-shadow:0 0 0 0 rgba(45,140,122,0)}}
  .week-pill{background:rgba(196,126,31,.10);border:1px solid rgba(196,126,31,.3);color:var(--accent-2);padding:6px 14px;border-radius:100px;font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.1em;text-transform:uppercase;font-weight:600}
  .today-day{font-family:'Fraunces',serif;font-weight:300;font-size:clamp(36px,5vw,56px);letter-spacing:-.02em;text-transform:capitalize;line-height:1;margin-bottom:6px;color:var(--ink)}
  .today-date{color:var(--ink-soft);font-size:14px;margin-bottom:28px}
  .today-providers{display:grid;gap:16px}
  .provider-card{background:var(--panel);border:1px solid var(--line);border-radius:16px;padding:20px 24px;display:flex;justify-content:space-between;align-items:center;transition:transform .25s,border-color .25s,box-shadow .25s;flex-wrap:wrap;gap:12px;box-shadow:var(--shadow-soft)}
  .provider-card:hover{transform:translateX(4px);border-color:var(--line-strong);box-shadow:0 6px 20px -8px rgba(40,30,15,.12)}
  .provider-name{display:flex;align-items:center;gap:14px}
  .provider-dot{width:14px;height:14px;border-radius:50%;flex-shrink:0}
  .provider-daimel .provider-dot{background:var(--staff-daimel);box-shadow:0 0 12px rgba(58,109,184,.35)}
  .provider-giselle .provider-dot{background:var(--staff-giselle);box-shadow:0 0 12px rgba(184,67,138,.35)}
  .provider-title{font-family:'Fraunces',serif;font-size:22px;font-weight:400;letter-spacing:-.01em;color:var(--ink)}
  .provider-label{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-dim)}
  .staff-chip{background:var(--bg-soft);border:1px solid var(--line);padding:6px 12px;border-radius:100px;font-size:12px;font-weight:500;display:flex;align-items:center;gap:6px;color:var(--ink)}
  .staff-chip::before{content:"";width:6px;height:6px;border-radius:50%}
  .staff-chip.daimel::before{background:var(--staff-daimel)}
  .staff-chip.giselle::before{background:var(--staff-giselle)}
  .empty-day{color:var(--ink-dim);font-style:italic;font-size:14px}
  .section-title{display:flex;align-items:baseline;gap:16px;margin-bottom:24px}
  .section-title h2{font-family:'Fraunces',serif;font-weight:300;font-size:32px;letter-spacing:-.02em;color:var(--ink)}
  .section-title h2 em{font-style:italic;color:var(--accent)}
  .section-title .subline{flex:1;height:1px;background:var(--line)}
  .section-title .meta{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--ink-dim);letter-spacing:.1em;text-transform:uppercase}
  .week-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:10px;margin-bottom:56px}
  .day-card{background:var(--panel);border:1px solid var(--line);border-radius:14px;padding:16px 14px;min-height:200px;display:flex;flex-direction:column;transition:border-color .2s,transform .2s,box-shadow .2s;box-shadow:var(--shadow-soft)}
  .day-card.is-today{border-color:var(--accent);background:linear-gradient(180deg,rgba(45,140,122,.05),var(--panel));box-shadow:0 0 0 1px var(--accent),0 8px 20px -10px rgba(45,140,122,.25)}
  .day-name{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.15em;text-transform:uppercase;color:var(--ink-dim);margin-bottom:4px}
  .day-card.is-today .day-name{color:var(--accent)}
  .day-num{font-family:'Fraunces',serif;font-size:28px;font-weight:300;letter-spacing:-.02em;line-height:1;margin-bottom:14px;color:var(--ink)}
  .day-providers{display:flex;flex-direction:column;gap:10px;flex:1}
  .option-group{display:flex;flex-direction:column;gap:4px}
  .option-label{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-dim)}
  .day-provider{background:var(--bg-soft);border-radius:8px;padding:6px 9px;font-size:10px;border-left:3px solid}
  .day-provider.daimel{border-color:var(--staff-daimel)}
  .day-provider.giselle{border-color:var(--staff-giselle)}
  .dp-name{font-weight:600;font-size:10px;margin-bottom:1px;letter-spacing:.02em;color:var(--ink)}
  footer{margin-top:60px;padding-top:24px;border-top:1px solid var(--line);color:var(--ink-dim);font-size:12px;display:flex;justify-content:space-between;flex-wrap:wrap;gap:8px}
  footer .mono{font-family:'JetBrains Mono',monospace}
  @media (max-width:900px){.week-grid{grid-template-columns:repeat(3,1fr)}}
  @media (max-width:600px){body{padding:20px 14px 60px}.today{padding:24px 22px;border-radius:18px}.week-grid{grid-template-columns:repeat(2,1fr)}.provider-card{padding:16px 18px}.provider-title{font-size:18px}}
  @media (max-width:420px){.week-grid{grid-template-columns:1fr}}
</style>
</head>
<body>
<div class="wrap">
  <header>
    <div class="brand">
      <span class="brand-tag">Clinicexperts · Telehealth</span>
      <h1>Horario <em>Daimel & Giselle</em></h1>
    </div>
    <div class="clock">
      <strong id="clock-day">—</strong>
      <span id="clock-date">—</span><br>
      <span id="clock-time">—</span>
    </div>
  </header>

  <section class="today">
    <div class="today-head">
      <span class="today-label"><span class="pulse"></span> Hoy</span>
      <span class="week-pill" id="today-week">Semana —</span>
    </div>
    <h2 class="today-day" id="today-day-name">—</h2>
    <p class="today-date" id="today-full-date">—</p>
    <div class="today-providers" id="today-providers"></div>
  </section>

  <div class="section-title">
    <h2>Esta <em>semana</em></h2>
    <div class="subline"></div>
    <span class="meta" id="week-range">—</span>
  </div>
  <div class="week-grid" id="week-grid"></div>

  <footer>
    <span>Horario Daimel & Giselle · Opciones A & B (lun-vie) · Ciclo de 2 semanas</span>
    <span class="mono" id="cycle-info">—</span>
  </footer>
</div>

<script>
/* DATA — Patrón: Ciclo de 2 semanas alternadas */
const SCHEDULE = {
  1: {
    Mon: {A: "DAIMEL PEREZ", B: "GISELLE CABEZAS"},
    Tue: {A: "GISELLE CABEZAS", B: "DAIMEL PEREZ"},
    Wed: {A: "DAIMEL PEREZ", B: "GISELLE CABEZAS"},
    Thu: {A: "GISELLE CABEZAS", B: "DAIMEL PEREZ"},
    Fri: {A: "DAIMEL PEREZ", B: "GISELLE CABEZAS"},
    Sat: {A: "GISELLE CABEZAS", B: null},
    Sun: {A: "GISELLE CABEZAS", B: null}
  },
  2: {
    Mon: {A: "GISELLE CABEZAS", B: "DAIMEL PEREZ"},
    Tue: {A: "DAIMEL PEREZ", B: "GISELLE CABEZAS"},
    Wed: {A: "GISELLE CABEZAS", B: "DAIMEL PEREZ"},
    Thu: {A: "DAIMEL PEREZ", B: "GISELLE CABEZAS"},
    Fri: {A: "GISELLE CABEZAS", B: "DAIMEL PEREZ"},
    Sat: {A: "DAIMEL PEREZ", B: null},
    Sun: {A: "DAIMEL PEREZ", B: null}
  }
};

const CYCLE_START = new Date(2026, 3, 27);
const DAY_KEYS = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
const DAY_NAMES_ES = {Sun:'Domingo',Mon:'Lunes',Tue:'Martes',Wed:'Miércoles',Thu:'Jueves',Fri:'Viernes',Sat:'Sábado'};
const DAY_NAMES_ES_SHORT = {Sun:'Dom',Mon:'Lun',Tue:'Mar',Wed:'Mié',Thu:'Jue',Fri:'Vie',Sat:'Sáb'};
const MONTHS_ES = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
const STAFF_KEYS = {"DAIMEL PEREZ":"daimel","GISELLE CABEZAS":"giselle"};

function startOfDay(d){return new Date(d.getFullYear(),d.getMonth(),d.getDate())}
function daysBetween(a,b){return Math.floor((startOfDay(b)-startOfDay(a))/86400000)}
function dayKey(date){return DAY_KEYS[date.getDay()]}
function getCycleWeek(date){const diff=daysBetween(CYCLE_START,date);const wi=Math.floor(diff/7);return((wi%2)+2)%2+1}
function getMondayOf(date){const d=startOfDay(date);const dow=d.getDay();const offset=dow===0?-6:1-dow;d.setDate(d.getDate()+offset);return d}
function fmtDateLong(d){return `${d.getDate()} de ${MONTHS_ES[d.getMonth()]} de ${d.getFullYear()}`}
function fmtDateShort(d){return `${d.getDate()} ${MONTHS_ES[d.getMonth()].slice(0,3)}`}

function getStaffFor(date){
  const week=getCycleWeek(date);const dk=dayKey(date);
  const options=SCHEDULE[week][dk]||{A:"",B:null};
  return{week,options};
}

function renderClock(){
  const now=new Date();
  document.getElementById('clock-day').textContent=DAY_NAMES_ES[dayKey(now)];
  document.getElementById('clock-date').textContent=fmtDateLong(now);
  document.getElementById('clock-time').textContent=now.toLocaleTimeString('es-ES',{hour:'2-digit',minute:'2-digit'});
}

function staffChip(staff){const k=STAFF_KEYS[staff]||'daimel';return `<span class="staff-chip ${k}">${staff}</span>`}

function renderStaffCard(option,label){
  const cls=STAFF_KEYS[option];
  return `<div class="provider-card provider-${cls}"><div style="flex:1"><span class="provider-label">${label}</span><div class="provider-name"><span class="provider-dot"></span><span class="provider-title">${option}</span></div></div><div class="staff-list">${staffChip(option)}</div></div>`;
}

function renderToday(){
  const now=new Date();const{week,options}=getStaffFor(now);
  document.getElementById('today-week').textContent=`Semana ${week}`;
  document.getElementById('today-day-name').textContent=DAY_NAMES_ES[dayKey(now)];
  document.getElementById('today-full-date').textContent=fmtDateLong(now);
  const cont=document.getElementById('today-providers');
  if(!options.A){cont.innerHTML=`<div class="provider-card"><span class="empty-day">Sin datos</span></div>`;return}
  let html=renderStaffCard(options.A,"Opción A");
  if(options.B)html+=renderStaffCard(options.B,"Opción B");
  cont.innerHTML=html;
}

function renderWeek(){
  const now=new Date();const monday=getMondayOf(now);const grid=document.getElementById('week-grid');
  const order=['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];let html='';const todayDate=startOfDay(now).getTime();
  for(let i=0;i<7;i++){
    const d=new Date(monday);d.setDate(monday.getDate()+i);
    const isToday=startOfDay(d).getTime()===todayDate;
    const{options}=getStaffFor(d);const dk=order[i];
    let staffHtml='';
    if(!options.A){staffHtml=`<div class="empty-day">— —</div>`}
    else{
      staffHtml=`<div class="option-group"><span class="option-label">A</span><div class="day-provider ${STAFF_KEYS[options.A]}"><div class="dp-name">${options.A.split(' ')[0]}</div></div></div>`;
      if(options.B){
        staffHtml+=`<div class="option-group"><span class="option-label">B</span><div class="day-provider ${STAFF_KEYS[options.B]}"><div class="dp-name">${options.B.split(' ')[0]}</div></div></div>`;
      }
    }
    html+=`<div class="day-card ${isToday?'is-today':''}"><div class="day-name">${DAY_NAMES_ES_SHORT[dk]}</div><div class="day-num">${d.getDate()}</div><div class="day-providers">${staffHtml}</div></div>`;
  }
  grid.innerHTML=html;const sunday=new Date(monday);sunday.setDate(monday.getDate()+6);
  document.getElementById('week-range').textContent=`${fmtDateShort(monday)} – ${fmtDateShort(sunday)}`;
}

function renderCycleInfo(){const sd=CYCLE_START;const pad=n=>n.toString().padStart(2,'0');
  document.getElementById('cycle-info').textContent=`Anclaje: ${pad(sd.getDate())}/${pad(sd.getMonth()+1)}/${sd.getFullYear()}`;
}

function init(){
  renderClock();renderToday();renderWeek();renderCycleInfo();
  setInterval(renderClock,30000);
  const now=new Date();const tomorrow=new Date(now.getFullYear(),now.getMonth(),now.getDate()+1,0,0,5);
  setTimeout(()=>{renderToday();renderWeek();renderClock()},tomorrow-now);
}
init();
</script>
</body>
</html>
